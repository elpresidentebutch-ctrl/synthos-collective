# SYNTHOS Agent Configuration
# Copy to .env and configure for your environment
# NEVER commit actual private keys to git

# ========== AGENT IDENTITY ==========
AGENT_ID=agent_local_001
AGENT_PRIVATE_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
HARDWARE_ID=local_test_machine_001

# ========== SECURITY - HSM SUPPORT ==========
HSM_ENABLED=false
# HSM_SLOT=0
# HSM_PIN=1234

# Key Rotation (grace period for dual-signing)
# AGENT_PRIVATE_KEY_PREVIOUS=ff00112233445566778899aabbccddeeff00112233445566778899aabbccdd
# KEY_ROTATION_ACTIVE_UNTIL=2026-04-25

# ========== NETWORK ==========
NETWORK_ID=synthos_testnet
P2P_PORT=8000
RPC_PORT=8080
RPC_LISTEN_ADDR=0.0.0.0:8080

# ========== CONSENSUS ==========
CONSENSUS_TIMEOUT=10s
BLOCK_INTERVAL=5s
MIN_VALIDATORS=3
FINALITY_THRESHOLD=2

# ========== REPUTATION & STAKING ==========
INITIAL_STAKE=1000
INITIAL_REPUTATION=100
MIN_REPUTATION_VALIDATOR=100
MIN_REPUTATION_GOVERNOR=200

# ========== STORAGE ==========
DATA_DIR=./data
STATE_DB=./data/state.db
LOG_LEVEL=info
LOG_FORMAT=json
