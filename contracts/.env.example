# Copy to .env (never commit .env). Used by Hardhat networks in hardhat.config.js

# Testnet / mainnet deployer (hex private key, 0x-prefixed)
# PRIVATE_KEY=0x...

SYNTHOS_RPC_URL=https://your-rpc.example
SYNTHOS_CHAIN_ID=1234

GEMINI_RPC_URL=https://your-gemini-rpc.example
GEMINI_CHAIN_ID=2048

# Timelock min delay in seconds (deploy script default: 60 on hardhat, 172800 elsewhere)
# TIMELOCK_MIN_DELAY=172800
